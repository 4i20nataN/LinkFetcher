{
  "name": "linkfetcher",
  "private": true,
  "version": "1.1.0",
  "description": "LinkFetcher - desktop yt-dlp frontend",
  "author": {
    "name": "Natan Vanim",
    "email": "natan.vanim@gmail.com"
  },
  "main": "dist/electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && npm run build:electron",
    "build:electron": "esbuild electron/main.cjs --bundle --platform=node --outfile=dist/electron/main.cjs --external:electron --format=cjs && node -e \"require('fs').copyFileSync('electron/preload.cjs','dist/electron/preload.cjs')\"",
    "build:native-host": "node scripts/build-native-host.cjs",
    "install:host": "node scripts/install-native-host.cjs",
    "start": "node dist/server.cjs",
    "electron:dev": "node scripts/electron-dev.cjs",
    "clean": "rm -rf dist server.js",
    "package:win": "npm run build && npx electron-builder --win",
    "sign:win": "node scripts/sign-windows.cjs",
    "prepare:resources": "node scripts/prepare-resources.cjs",
    "lint": "tsc --noEmit",
    "devtools:mcp": "npx chrome-devtools-mcp@latest --browser-url=http://127.0.0.1:9222",
    "generate:signing-key": "node scripts/generate-signing-key.cjs",
    "build:mobile": "vite build && npx cap sync android",
    "build:android": "npm run build:mobile && npx cap open android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "extract-zip": "^2.0.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "chrome-devtools-mcp": "^1.6.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.linkfetcher.app",
    "productName": "LinkFetcher",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-web/index.html",
      "dist-web/assets/**",
      "dist/electron/**",
      "dist/server.cjs",
      "dist/server.cjs.map",
      "electron/main.cjs",
      "electron/preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LinkFetcher",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  }
}
